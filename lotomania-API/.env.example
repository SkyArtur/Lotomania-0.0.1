SECRET_KEY=senha-secreta-do-projeto
DEBUG=True
DJANGO_ENV=development
# Django's ALLOWED_HOSTS does not support CIDR ranges (e.g. 192.168.1.0/24) -
# list exact hosts/IPs, such as your machine's LAN IP if you need access from
# another device (e.g. a phone) on the same network.
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
DATABASE_URL=postgres://usuario:senha@db:5432/appname
POSTGRES_DB=db
POSTGRES_USER=usuario
POSTGRES_PASSWORD=senha
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
